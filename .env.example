# Server
PORT=3000

# Auth (required in production)
JWT_SECRET=change-me-in-production

# PostgreSQL (optional — falls back to in-memory store)
# DATABASE_URL=postgres://vantage:vantage@localhost:5432/vantage_earn

# Liquidity reserve (default 0.10 = 10%)
# LIQUIDITY_RESERVE_RATIO=0.10

# Rate limiting (requests per IP per window)
# RATE_LIMIT_MAX=60
# AUTH_RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_SECS=60

# AI Copilot (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
