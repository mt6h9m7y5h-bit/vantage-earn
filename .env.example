# Server
PORT=3000

# Auth (required in production)
JWT_SECRET=change-me-in-production

# ── PostgreSQL / DATABASE_URL ────────────────────────────────────────────────
#
# LOCAL DEV ohne Docker:
#   DATABASE_URL auskommentieren → API nutzt In-Memory-Store (Daten gehen beim
#   Neustart verloren). Danach: ./scripts/restart-dev.sh
#
# LOCAL DEV mit Docker:
#   docker compose up -d postgres   # oder: ./scripts/db-up.sh
#   DATABASE_URL=postgres://vantage:vantage@localhost:5432/vantage_earn
#
# PRODUCTION (Render):
#   DATABASE_URL nur in Render Dashboard / render.yaml setzen — niemals die
#   externe Render-URL in die lokale .env kopieren (SSL/Netzwerk blockiert oft).
#
# Without DATABASE_URL the API uses an in-memory store (data lost on restart).
# DATABASE_URL=postgres://vantage:vantage@localhost:5432/vantage_earn

# Liquidity reserve (default 0.10 = 10%)
# LIQUIDITY_RESERVE_RATIO=0.10

# Rate limiting (requests per IP per window)
# RATE_LIMIT_MAX=60
# AUTH_RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_SECS=60

# AI Copilot (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Payout (production min = 170 EUR equivalent in USDT)
# PAYOUT_DEMO_MODE=true

# Rewarded video ads (default: mock timer for dev/tests)
# AD_PROVIDER=mock              # mock | adinplay | applixir
# AD_WATCH_DURATION_SECS=30

# AdInPlay (recommended for indie/solo devs — no business email required)
# ADINPLAY_PUBLISHER_ID=ABC
# ADINPLAY_SITE_ID=your-domain.com
# ADINPLAY_TAG_URL=https://api.adinplay.com/libs/aiptag/pub/ABC/your-domain.com/tag.min.js

# AppLixir (alternative live provider)
# APPLIXIR_API_KEY=xxxx-xxxx-xxxx
# APPLIXIR_APP_ID=xxxx-xxxx-xxxx   # alias for APPLIXIR_API_KEY

# Admin dashboard (/admin UI, API header X-Admin-Secret). Required for admin panel.
# Without this, all admin requests return 503; wrong value returns 401.
# Local: must match the secret you type at /admin (restart after change: ./scripts/restart-dev.sh).
# Render: Dashboard → Environment → ADMIN_SECRET (render.yaml generateValue only applies on first deploy).
# Production uses a custom secret — copy the same value here for local dev, e.g.:
# ADMIN_SECRET=VantageAdmin2026!Xk9m
ADMIN_SECRET=change-me-admin-secret

# Build / release metadata (optional — set in Docker build ARG GIT_COMMIT)
# GIT_COMMIT=abc1234
# RUST_ENV=development

# E-Mail (Vorbereitung — SMTP noch nicht angebunden)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=VANTAGE-EARN

# BitLabs Offerwall (Phase C)
# BITLABS_APP_TOKEN=           # App/API Token (Dashboard → Apps → Integration)
# BITLABS_SECRET_KEY=          # App Secret — callback HMAC verification
# BITLABS_S2S_KEY=             # Server-to-server API key (future catalog API)
# OFFERWALL_ENABLED=false      # true when token + secret set and callbacks tested
# OFFERWALL_PRIMARY=bitlabs    # bitlabs | cpx | both
